<?xml version="1.0" encoding="utf-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:Assignment.Views"
    x:Class="Assignment.AppShell">

    <!-- Sign In -->
    <ShellContent
        Route="SignInPage"
        ContentTemplate="{DataTemplate views:SignInPage}" />

    <!-- Sign Up -->
    <ShellContent
        Route="SignUpPage"
        ContentTemplate="{DataTemplate views:SignUpPage}" />

    <!-- Main -->
    <ShellContent
        Route="MainPage"
        ContentTemplate="{DataTemplate views:MainPage}" />

    <!-- Account -->
    <ShellContent
        Route="AccountPage"
        ContentTemplate="{DataTemplate views:AccountPage}" />

    <!-- Admin -->
    <ShellContent
        Route="AdminPage"
        ContentTemplate="{DataTemplate views:AdminPage}" />
    <ShellContent 
        Route="UsersListPage" 
        ContentTemplate="{DataTemplate views:UsersListPage}" />

</Shell>

