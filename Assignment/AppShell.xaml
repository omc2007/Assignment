<?xml version="1.0" encoding="utf-8" ?>
<Shell
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ReCAI.Views"
    x:Class="ReCAI.AppShell"
    FlyoutBehavior="Flyout">
    <!-- SignIn/SignUp מחוץ לתפריט -->
    <ShellContent Route="SignInPage" ContentTemplate="{DataTemplate views:SignInPage}" />
    <ShellContent Route="SignUpPage" ContentTemplate="{DataTemplate views:SignUpPage}" />

    <!-- תפריט קבוע לכל האפליקציה -->
    <FlyoutItem x:Name="HomeItem" Title="Home" Route="MainPage">
        <ShellContent ContentTemplate="{DataTemplate views:MainPage}" />
    </FlyoutItem>


    <FlyoutItem x:Name="AccountItem" Title="Account" Route="AccountPage">
    <ShellContent ContentTemplate="{DataTemplate views:AccountPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="UsersItem" Title="Users" Route="UsersListPage">
        <ShellContent ContentTemplate="{DataTemplate views:UsersListPage}" />
    </FlyoutItem>

    <FlyoutItem x:Name="AdminItem" Title="Admin" Route="AdminPage">
        <ShellContent ContentTemplate="{DataTemplate views:AdminPage}" />
    </FlyoutItem>

</Shell>


