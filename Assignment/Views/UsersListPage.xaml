<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="ReCAI.Views.UsersListPage"
    Title="Users List">

    <Grid Padding="16" RowDefinitions="Auto,Auto,*" RowSpacing="12">

        <Label
            Grid.Row="0"
            Text="Users List"
            FontSize="20"
            FontAttributes="Bold" />

        <Grid Grid.Row="1" ColumnDefinitions="*,Auto" ColumnSpacing="8">
            <SearchBar
                Placeholder="find user"
                Text="{Binding SearchText}" />

            <Button
                Grid.Column="1"
                Text="⏷"
                Command="{Binding ClearSearchCommand}"
                WidthRequest="44"
                HeightRequest="44" />
        </Grid>

        <CollectionView
            Grid.Row="2"
            ItemsSource="{Binding Users}"
            SelectionMode="Single"
            SelectedItem="{Binding SelectedUser, Mode=TwoWay}">

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10" RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto">
                        <Label
                            Grid.Row="0"
                            Grid.Column="0"
                            Text="{Binding FullName}"
                            FontAttributes="Bold" />

                        <Label
                            Grid.Row="0"
                            Grid.Column="1"
                            Text="{Binding CreatedAtShort}"
                            FontSize="12"
                            VerticalOptions="Center" />

                        <Label
                            Grid.Row="1"
                            Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Text="{Binding Email}"
                            FontSize="12" />

                        <BoxView
                            Grid.RowSpan="2"
                            Color="#000000"
                            Opacity="0.06"
                            HeightRequest="1"
                            VerticalOptions="End"
                            HorizontalOptions="Fill" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>

    </Grid>
</ContentPage>
