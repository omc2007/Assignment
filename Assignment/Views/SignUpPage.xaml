<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ReCAI.Views.SignUpPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Sign Up"
    Shell.NavBarIsVisible="False"
    Shell.FlyoutBehavior="Disabled">

    <Grid>

        <Image
            Source="signup_background.png"
            Aspect="AspectFill" />

        <BoxView BackgroundColor="#35FFFFFF" />

        <ScrollView>
            <VerticalStackLayout
                Padding="30"
                Spacing="16"
                VerticalOptions="Center"
                HorizontalOptions="Fill"
                Margin="0,40,0,20">

                <Label
                    Text="Create Account"
                    FontSize="28"
                    FontAttributes="Bold"
                    TextColor="#123B66"
                    HorizontalOptions="Center" />

                <Frame
                    BackgroundColor="#CCFFFFFF"
                    CornerRadius="24"
                    Padding="20"
                    HasShadow="True">

                    <VerticalStackLayout Spacing="14">

                        <Entry
                            Placeholder="First Name"
                            Text="{Binding FirstName}"
                            TextColor="Black"
                            PlaceholderColor="Gray" />

                        <Entry
                            Placeholder="Last Name"
                            Text="{Binding LastName}"
                            TextColor="Black"
                            PlaceholderColor="Gray" />

                        <Entry
                            Placeholder="Email"
                            Text="{Binding Email}"
                            Keyboard="Email"
                            TextColor="Black"
                            PlaceholderColor="Gray" />

                        <Entry
                            Placeholder="Password"
                            Text="{Binding Password}"
                            IsPassword="{Binding IsPassword}"
                            TextColor="Black"
                            PlaceholderColor="Gray" />

                        <Entry
                            Placeholder="Mobile"
                            Text="{Binding Mobile}"
                            Keyboard="Telephone"
                            TextColor="Black"
                            PlaceholderColor="Gray" />

                        <Button
                            Text="Sign Up"
                            Command="{Binding SignUpCommand}" />

                        <Button
                            Text="Back to Sign In"
                            Command="{Binding GoToSignInCommand}" />

                        <Label
                            Text="{Binding ErrorMessage}"
                            TextColor="Red"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center" />

                    </VerticalStackLayout>
                </Frame>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentPage>